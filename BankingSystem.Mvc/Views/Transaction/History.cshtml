@model TransactionHistoryViewModel

@{
    ViewData["Title"] = "Transaction History";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Transaction History</h2>
        <p class="text-muted mb-0">Account @Model.AccountNumber | Current Balance: @Model.CurrentBalance.ToString("C")</p>
    </div>
    <a class="btn btn-outline-primary" asp-controller="Account" asp-action="Details" asp-route-id="@Model.AccountId">Back to Account</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Date</th>
                <th>Type</th>
                <th>Amount</th>
                <th>Description</th>
                <th>Balance After</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var transaction in Model.Transactions)
        {
            <tr>
                <td>@transaction.TransactionDate.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@transaction.TransactionType</td>
                <td>@transaction.Amount.ToString("C")</td>
                <td>@(string.IsNullOrWhiteSpace(transaction.Description) ? "-" : transaction.Description)</td>
                <td>@transaction.BalanceAfter.ToString("C")</td>
            </tr>
        }
        </tbody>
    </table>
</div>
